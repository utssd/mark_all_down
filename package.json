{
  "name": "markalldown",
  "version": "1.0.0",
  "description": "Markdown reader and Mermaid diagram editor",
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "MarkAllDown"
  },
  "homepage": "https://github.com/utssd/mark_all_down",
  "main": "main.js",
  "scripts": {
    "start": "unset ELECTRON_RUN_AS_NODE && electron .",
    "build": "electron-builder --publish never --linux AppImage",
    "build:linux": "electron-builder --publish never --linux AppImage tar.gz",
    "build:deb": "electron-builder --publish never --linux deb",
    "build:mac": "electron-builder --publish never --mac dmg zip",
    "build:all": "electron-builder --publish never --linux AppImage tar.gz --mac dmg zip",
    "release": "bash release.sh",
    "install:linux": "bash install-linux.sh",
    "setup-hooks": "bash setup-hooks.sh",
    "format": "bash hooks/format-all.sh",
    "lint": "eslint main.js preload.js app.js agents/**/*.js",
    "vendor:webdav": "esbuild node_modules/webdav/dist/node/index.js --bundle --platform=node --target=node20 --format=cjs --outfile=vendors/webdav.js",
    "vendor:ssh2": "esbuild node_modules/ssh2/lib/index.js --bundle --platform=node --target=node20 --format=cjs --outfile=vendors/ssh2.js --external:cpu-features --external:*.node",
    "test:packaging": "node scripts/verify-packaging.js",
    "test:unit": "node --test tests/process-lifecycle.test.js agents/_runtime/smart-rss/__tests__/*.test.js",
    "test:shell": "bash tests/cleanup-stale-mad.test.sh",
    "test": "npm run test:unit && npm run test:shell"
  },
  "build": {
    "appId": "com.markalldown.app",
    "productName": "MarkAllDown",
    "icon": "icon.png",
    "npmRebuild": true,
    "afterPack": "build/adhoc-sign.js",
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Utility",
      "icon": "icon.png",
      "mimeTypes": [
        "text/markdown"
      ],
      "fileAssociations": [
        {
          "ext": "md",
          "mimeType": "text/markdown",
          "name": "Markdown"
        },
        {
          "ext": "markdown",
          "mimeType": "text/markdown",
          "name": "Markdown"
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "icon": "icon.png",
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "fileAssociations": [
        {
          "ext": "md",
          "mimeType": "text/markdown",
          "name": "Markdown",
          "role": "Editor"
        },
        {
          "ext": "markdown",
          "mimeType": "text/markdown",
          "name": "Markdown",
          "role": "Editor"
        },
        {
          "ext": "txt",
          "name": "Text",
          "role": "Editor"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "icon.png"
    },
    "files": [
      "main.js",
      "monitor.js",
      "preload.js",
      "preload-popup.js",
      "process-lifecycle.js",
      "index.html",
      "diff.html",
      "plan.html",
      "app.js",
      "diff-renderer.js",
      "plan-renderer.js",
      "style.css",
      "icon.png",
      "logo.png",
      "build/entitlements.mac.plist",
      "agents/**/*.{js,md,html,css,json,svg,png}",
      "claude-diff/**/*.js",
      "windows/**/*.js",
      "vendors/webdav.js",
      "vendors/ssh2.js",
      "node_modules/@xterm/xterm/css/xterm.css",
      "node_modules/@xterm/xterm/lib/**",
      "node_modules/@xterm/addon-fit/lib/**",
      "node_modules/@xterm/addon-web-links/lib/**",
      "node_modules/@xterm/addon-search/lib/**",
      "node_modules/node-pty/**",
      "node_modules/pdfjs-dist/build/pdf.min.mjs",
      "node_modules/pdfjs-dist/build/pdf.worker.min.mjs",
      "node_modules/pdfjs-dist/web/pdf_viewer.css",
      "node_modules/better-sqlite3/**",
      "node_modules/@xenova/**"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/@xenova/**"
    ]
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^11.10.0",
    "codemirror": "^5.65.18",
    "jszip": "^3.10.1",
    "katex": "^0.16.33",
    "mammoth": "^1.11.0",
    "marked": "13.0.2",
    "mermaid": "11.4.1",
    "pdf-parse": "^2.4.3",
    "pdfjs-dist": "^5.4.296",
    "ssh2": "^1.17.0",
    "webdav": "^4.11.4",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "prettier": "^3.8.1"
  }
}
